---
import BaseLayout from '../layouts/BaseLayout.astro';
import { PRICING } from '@/lib/payment';

const plans = [
  {
    id: 'free',
    name: 'Free',
    price: '$0',
    period: 'forever',
    description: 'Try before you buy — perfect for occasional practice.',
    features: [
      '2 free worksheets per topic',
      'Standard difficulty levels',
      'PDF format, ready to print',
      'No account needed',
    ],
    cta: 'Get Started Free',
    ctaLink: '/#grades',
    highlighted: false,
    badge: null,
  },
  {
    id: 'premium-monthly',
    name: 'Premium',
    price: PRICING.monthly.price,
    period: PRICING.monthly.period,
    description: 'Full access for serious math practice. Cancel anytime.',
    features: PRICING.monthly.features,
    cta: 'Subscribe Monthly',
    ctaLink: '/checkout/monthly/',
    highlighted: true,
    badge: 'Most Popular',
  },
  {
    id: 'premium-yearly',
    name: 'Premium Yearly',
    price: PRICING.yearly.price,
    period: PRICING.yearly.period,
    description: 'Best value — save over 58% compared to monthly.',
    features: PRICING.yearly.features,
    cta: 'Subscribe Yearly',
    ctaLink: '/checkout/yearly/',
    highlighted: false,
    badge: 'Best Value',
  },
  {
    id: 'lifetime',
    name: 'Lifetime Access',
    price: PRICING.lifetime.price,
    period: PRICING.lifetime.period,
    description: 'One payment. Forever access. Perfect for homeschoolers.',
    features: PRICING.lifetime.features,
    cta: 'Get Lifetime Access',
    ctaLink: '/checkout/lifetime/',
    highlighted: false,
    badge: null,
  },
];

const faqs = [
  { q: 'Are the free worksheets really free?', a: 'Yes! Every topic includes at least 2 free worksheets. No sign-up, no credit card — just download and print.' },
  { q: 'What payment methods do you accept?', a: 'We use LemonSqueezy for secure payment processing. They accept Visa, Mastercard, American Express, PayPal, and more.' },
  { q: 'Can I cancel my subscription?', a: 'Absolutely. You can cancel anytime from your LemonSqueezy customer portal. Your access continues until the end of the billing period.' },
  { q: 'Do you offer refunds?', a: 'Yes! LemonSqueezy handles refunds. If you\'re not satisfied, contact us within 14 days of purchase for a full refund.' },
  { q: 'Can schools or teachers purchase?', a: 'Yes! We offer classroom licenses. Contact us for bulk pricing and invoice options.' },
  { q: 'How do I access premium worksheets after purchasing?', a: 'After purchase, you\'ll be redirected to a download page with your premium access. You can also access premium content by visiting any topic page and clicking the "Unlock Full Access" button.' },
  { q: 'Are new worksheets added regularly?', a: 'Yes! We\'re constantly adding new worksheets, topics, and difficulty levels. A Premium subscription gives you access to everything new.' },
];
---

<BaseLayout title="Pricing — MathPractice K5" description="Choose the perfect plan for your child's math practice. Free worksheets available for every topic. Premium plans unlock unlimited access.">
  <!-- Page Header -->
  <section class="section" style="padding: 60px 0 20px;">
    <div class="container" style="text-align: center; max-width: 720px; margin: 0 auto;">
      <div style="display: inline-flex; align-items: center; gap: 8px; background: var(--accent-light); color: var(--accent); font-size: 0.8125rem; font-weight: 600; padding: 6px 14px; border-radius: 20px; margin-bottom: 16px;">
        🔒 Secure Payments via LemonSqueezy
      </div>
      <h1 style="font-size: 2.5rem; font-weight: 800; letter-spacing: -0.03em; line-height: 1.15; margin-bottom: 12px;">
        Simple, Transparent Pricing
      </h1>
      <p style="font-size: 1.125rem; color: var(--text-secondary); max-width: 540px; margin: 0 auto;">
        Start with free worksheets on every topic. Upgrade when you're ready for full access.
      </p>
    </div>
  </section>

  <!-- Pricing Cards -->
  <section class="section" style="padding: 40px 0 60px;">
    <div class="container">
      <div class="pricing-grid">
        {plans.map((plan) => (
          <div class={`pricing-card${plan.highlighted ? ' pricing-card--highlighted' : ''}`}>
            {plan.badge && (
              <div class="pricing-badge">{plan.badge}</div>
            )}
            <div class="pricing-header">
              <h3 class="pricing-name">{plan.name}</h3>
              <div class="pricing-price">
                <span class="pricing-amount">{plan.price}</span>
                <span class="pricing-period">{plan.period}</span>
              </div>
              <p class="pricing-desc">{plan.description}</p>
            </div>
            <ul class="pricing-features">
              {plan.features.map((f) => (
                <li class="pricing-feature">
                  <svg width="16" height="16" viewBox="0 0 16 16" fill="none" style="flex-shrink: 0; margin-top: 2px;">
                    <path d="M13.3 4.3L6 11.6 2.7 8.3" stroke={plan.highlighted ? '#0075de' : '#2e7d32'} stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                  </svg>
                  <span>{f}</span>
                </li>
              ))}
            </ul>
            <div class="pricing-action">
              {plan.id === 'free' ? (
                <a href={plan.ctaLink} class="btn btn-secondary" style="width: 100%; justify-content: center;">
                  {plan.cta}
                </a>
              ) : (
                <a
                  href={plan.ctaLink}
                  class={`btn ${plan.highlighted ? 'btn-primary' : 'btn-secondary'}`}
                  style="width: 100%; justify-content: center;"
                >
                  {plan.cta}
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Feature Comparison Table -->
  <section class="section" style="padding: 0 0 60px;">
    <div class="container" style="max-width: 720px;">
      <h2 style="font-size: 1.5rem; font-weight: 700; text-align: center; margin-bottom: 32px;">What's Included</h2>
      <div class="comparison-table">
        <div class="comparison-row comparison-header">
          <div class="comparison-cell">Feature</div>
          <div class="comparison-cell comparison-free">Free</div>
          <div class="comparison-cell comparison-premium">Premium</div>
        </div>
        {[
          { feature: 'Worksheets per topic', free: '2', premium: 'Unlimited' },
          { feature: 'Difficulty levels', free: '1 (Easy)', premium: 'Easy, Medium, Hard' },
          { feature: 'Answer keys', free: 'Basic', premium: 'Complete' },
          { feature: 'New content added', free: '✓', premium: '✓' },
          { feature: 'PDF download', free: '✓', premium: '✓' },
          { feature: 'Ad-free experience', free: '—', premium: '✓' },
          { feature: 'Priority support', free: '—', premium: '✓' },
        ].map((row) => (
          <div class="comparison-row">
            <div class="comparison-cell">{row.feature}</div>
            <div class="comparison-cell comparison-free">{row.free}</div>
            <div class="comparison-cell comparison-premium">{row.premium}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="section" style="background: var(--bg-secondary); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
    <div class="container" style="max-width: 720px;">
      <h2 style="font-size: 1.5rem; font-weight: 700; text-align: center; margin-bottom: 40px;">Frequently Asked Questions</h2>
      <div class="faq-list">
        {faqs.map((faq) => (
          <details class="faq-item">
            <summary class="faq-question">{faq.q}</summary>
            <p class="faq-answer">{faq.a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA Banner -->
  <section class="section">
    <div class="container" style="text-align: center; max-width: 640px; margin: 0 auto;">
      <h2 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 12px;">Still Not Sure?</h2>
      <p style="color: var(--text-secondary); margin-bottom: 24px;">
        Start with our free worksheets and see if MathPractice K5 works for your child. No commitment needed.
      </p>
      <a href="/#grades" class="btn btn-primary">Try Free Worksheets</a>
    </div>
  </section>
</BaseLayout>

<style>
  .pricing-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(260px, 1fr));
    gap: 20px;
    align-items: start;
  }

  .pricing-card {
    background: var(--bg-secondary);
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    padding: 28px 24px;
    display: flex;
    flex-direction: column;
    position: relative;
    transition: all 0.15s ease;
  }

  .pricing-card:hover {
    box-shadow: var(--shadow-md);
  }

  .pricing-card--highlighted {
    border-color: var(--accent);
    border-width: 2px;
    box-shadow: var(--shadow-md);
    transform: scale(1.02);
    z-index: 1;
  }

  .pricing-badge {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--accent);
    color: white;
    font-size: 0.75rem;
    font-weight: 700;
    padding: 4px 16px;
    border-radius: 12px;
    white-space: nowrap;
  }

  .pricing-header {
    text-align: center;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--border-light);
    margin-bottom: 20px;
  }

  .pricing-name {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-tertiary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 8px;
  }

  .pricing-price {
    margin-bottom: 8px;
  }

  .pricing-amount {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--text-primary);
  }

  .pricing-period {
    font-size: 0.875rem;
    color: var(--text-tertiary);
  }

  .pricing-desc {
    font-size: 0.8125rem;
    color: var(--text-secondary);
    line-height: 1.5;
  }

  .pricing-features {
    list-style: none;
    padding: 0;
    margin: 0 0 24px;
    flex: 1;
  }

  .pricing-feature {
    display: flex;
    align-items: flex-start;
    gap: 8px;
    font-size: 0.8125rem;
    color: var(--text-secondary);
    padding: 6px 0;
    line-height: 1.4;
  }

  .pricing-action {
    margin-top: auto;
  }

  /* Comparison Table */
  .comparison-table {
    border: 1px solid var(--border);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .comparison-row {
    display: grid;
    grid-template-columns: 1fr 80px 100px;
    gap: 0;
  }

  .comparison-header {
    background: var(--bg-tertiary);
    font-weight: 600;
    font-size: 0.8125rem;
  }

  .comparison-cell {
    padding: 12px 16px;
    font-size: 0.875rem;
    color: var(--text-secondary);
    border-bottom: 1px solid var(--border-light);
  }

  .comparison-header .comparison-cell {
    color: var(--text-primary);
  }

  .comparison-free {
    text-align: center;
    font-weight: 500;
  }

  .comparison-premium {
    text-align: center;
    color: var(--accent);
    font-weight: 600;
  }

  .comparison-row:last-child .comparison-cell {
    border-bottom: none;
  }

  /* FAQ */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .faq-item {
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
  }

  .faq-question {
    padding: 16px 20px;
    font-size: 0.9375rem;
    font-weight: 600;
    cursor: pointer;
    user-select: none;
    display: flex;
    align-items: center;
    justify-content: space-between;
    color: var(--text-primary);
  }

  .faq-question::-webkit-details-marker {
    display: none;
  }

  .faq-question::after {
    content: '+';
    font-size: 1.25rem;
    color: var(--text-tertiary);
    transition: transform 0.2s ease;
  }

  .faq-item[open] .faq-question::after {
    content: '−';
  }

  .faq-answer {
    padding: 0 20px 16px;
    font-size: 0.875rem;
    color: var(--text-secondary);
    line-height: 1.6;
  }

  @media (max-width: 768px) {
    .pricing-card--highlighted {
      transform: none;
    }
    .comparison-row {
      grid-template-columns: 1fr 60px 80px;
    }
    .comparison-cell {
      padding: 10px 12px;
      font-size: 0.8125rem;
    }
  }
</style>
