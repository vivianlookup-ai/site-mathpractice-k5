---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Terms of Use" description="MathPractice K5 terms of use. Conditions for using our free printable math worksheets.">
  <div class="container" style="max-width: 720px; padding-top: 60px; padding-bottom: 60px;">
    <h1 style="font-size: 2rem; font-weight: 800; margin-bottom: 8px;">Terms of Use</h1>
    <p style="font-size: 0.875rem; color: var(--text-tertiary); margin-bottom: 32px;">Last updated: {new Date().toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}</p>

    <div style="line-height: 1.8; font-size: 0.9375rem; color: var(--text-secondary); display: flex; flex-direction: column; gap: 24px;">
      <section>
        <h2 style="font-size: 1.25rem; font-weight: 700; color: var(--text-primary); margin-bottom: 8px;">Free Use</h2>
        <p>All worksheets on MathPractice K5 are available for free personal and educational use. You may download, print, and distribute them to your students or children.</p>
      </section>

      <section>
        <h2 style="font-size: 1.25rem; font-weight: 700; color: var(--text-primary); margin-bottom: 8px;">Prohibited Uses</h2>
        <p>You may not sell, redistribute, or republish the worksheets for commercial purposes without a paid license. You may not claim ownership of the content.</p>
      </section>

      <section>
        <h2 style="font-size: 1.25rem; font-weight: 700; color: var(--text-primary); margin-bottom: 8px;">Paid Plans</h2>
        <p>Premium features may be offered in the future. These terms will be updated when paid plans are introduced.</p>
      </section>

      <section>
        <h2 style="font-size: 1.25rem; font-weight: 700; color: var(--text-primary); margin-bottom: 8px;">Contact</h2>
        <p>For questions about these terms, please <a href="/contact/">contact us</a>.</p>
      </section>
    </div>
  </div>
</BaseLayout>
