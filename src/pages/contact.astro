---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Contact Us" description="Contact MathPractice K5. Get in touch with questions, suggestions, or feedback about our math worksheets.">
  <div class="container" style="max-width: 640px; padding-top: 60px; padding-bottom: 60px;">
    <div style="text-align: center; margin-bottom: 40px;">
      <h1 style="font-size: 2rem; font-weight: 800; margin-bottom: 8px;">Contact Us</h1>
      <p style="font-size: 1rem; color: var(--text-secondary);">Have a question or suggestion? We'd love to hear from you.</p>
    </div>

    <div style="background: var(--bg-secondary); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 32px;">
      <form action="https://formspree.io/f/your-form-id" method="POST" style="display: flex; flex-direction: column; gap: 20px;">
        <div>
          <label for="name" style="display: block; font-size: 0.875rem; font-weight: 600; margin-bottom: 6px; color: var(--text-primary);">Name</label>
          <input type="text" id="name" name="name" required
            style="width: 100%; padding: 10px 14px; border: 1px solid var(--border); border-radius: var(--radius); font-family: Inter, sans-serif; font-size: 0.9375rem; background: var(--bg-primary); color: var(--text-primary);" />
        </div>
        <div>
          <label for="email" style="display: block; font-size: 0.875rem; font-weight: 600; margin-bottom: 6px; color: var(--text-primary);">Email</label>
          <input type="email" id="email" name="email" required
            style="width: 100%; padding: 10px 14px; border: 1px solid var(--border); border-radius: var(--radius); font-family: Inter, sans-serif; font-size: 0.9375rem; background: var(--bg-primary); color: var(--text-primary);" />
        </div>
        <div>
          <label for="message" style="display: block; font-size: 0.875rem; font-weight: 600; margin-bottom: 6px; color: var(--text-primary);">Message</label>
          <textarea id="message" name="message" rows={5} required
            style="width: 100%; padding: 10px 14px; border: 1px solid var(--border); border-radius: var(--radius); font-family: Inter, sans-serif; font-size: 0.9375rem; background: var(--bg-primary); color: var(--text-primary); resize: vertical;"></textarea>
        </div>
        <button type="submit" class="btn btn-primary" style="align-self: flex-start;">
          Send Message
        </button>
      </form>
      <p style="font-size: 0.8125rem; color: var(--text-tertiary); margin-top: 16px; text-align: center;">
        Or email us directly at <a href="mailto:hello@mathpracticek5.com">hello@mathpracticek5.com</a>
      </p>
    </div>
  </div>
</BaseLayout>
